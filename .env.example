# ── PostgreSQL (dev docker) ────────────────────────────────────────────────────
POSTGRES_PORT=5433
POSTGRES_USER=scholarly
POSTGRES_PASSWORD=scholarly_dev
POSTGRES_DB=scholarly

APP_DB_USER=scholarly_app
APP_DB_PASSWORD=scholarly_app_dev

# ── Drizzle ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgres://scholarly_app:scholarly_app_dev@localhost:5433/scholarly"
MIGRATION_DATABASE_URL="postgres://scholarly:scholarly_dev@localhost:5433/scholarly"

# ── App ───────────────────────────────────────────────────────────────────────
ORIGIN="http://localhost:5174"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# GitHub OAuth (opcional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Storage (MinIO / S3-compatible)
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="scholio"
# URL pública desde la que el navegador descarga las fotos
# En prod: https://storage.scholio.tech
STORAGE_PUBLIC_URL="http://localhost:9000"

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# MinIO (solo para docker-compose prod)
MINIO_ROOT_USER=""
MINIO_ROOT_PASSWORD=""

# ── Sentry ────────────────────────────────────────────────────────────────────
# Server-side DSN (privado, no en cliente)
SENTRY_DSN=""
# Public DSN (se expone al navegador para errores de cliente)
PUBLIC_SENTRY_DSN=""

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Obtener los price IDs desde el dashboard de Stripe → Products
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_TEAM_MONTHLY=""
